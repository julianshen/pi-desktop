{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Task 7 (assistant-ui-migration): "@/*" -> "./src/*" alias, required by
       shadcn's Vite installation flow (`npx shadcn add`) for its own
       generated imports. No other file in this project uses this alias —
       everything else keeps using relative imports; this exists purely so
       shadcn-generated files under src/components/{ui,assistant-ui}/ resolve
       the way the CLI writes them. */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
